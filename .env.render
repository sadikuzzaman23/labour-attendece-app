# Render Environment Variables for Telegram Bot Deployment
# Copy these variables into your Render dashboard (Settings > Environment)
# Use your actual values from .env file - DO NOT commit real secrets to GitHub

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
PORT=7860